---
import { getCollection, render } from 'astro:content'
import IsiReportCard from '../../components/IsiReportCard.astro'
import { type ArticleImages, formatArticleDate } from '../../lib/articles'
import Layout from '../../layouts/Layout.astro'

const allImageFiles = import.meta.glob<ArticleImages>(
  '/src/assets/articles/*.json',
  { eager: true },
)

export async function getStaticPaths() {
  const articles = await getCollection('articles')
  return articles.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const isHuman = entry.data.human === true
const author = entry.data.author
const sources = entry.data.sources ?? []
const isiSlugs = entry.data.isiSlugs ?? []

const images =
  allImageFiles[`/src/assets/articles/${entry.data.slug}.json`] ?? null

const linkedIsiReports =
  isiSlugs.length > 0
    ? (await getCollection('isi')).filter((r) =>
        isiSlugs.includes(r.id.replace(/\.md$/, '')),
      )
    : []
---

<Layout
  title={`${entry.data.title} | Individet`}
  description={entry.data.description}
  ogType="article"
  ogImage={images?.hero?.url}
  ogImageAlt={images?.hero?.alt}
>
  <article class="article-detail page-shell page-detail">
    <div class="meta-strip">
      <a href="/articles/" class="button-link button-link--secondary">
        Til reportasjer
      </a>
    </div>

    <section class="page-hero article-detail__hero">
      <div class="article-detail__hero-copy">
        <span class="eyebrow">Reportasje</span>
        <h1 class="page-hero__title">{entry.data.title}</h1>
        <p class="page-hero__lede">{entry.data.description}</p>
      </div>

      {
        images?.hero && (
          <figure class="article-detail__hero-figure">
            <img
              src={images.hero.url}
              alt={images.hero.alt}
              loading="eager"
              class="article-detail__hero-img"
            />
            <figcaption>
              {images.hero.attribution} — {images.hero.license}
            </figcaption>
          </figure>
        )
      }

      <div class="meta-strip">
        <time class="meta-pill" datetime={entry.data.date.toISOString()}>
          {formatArticleDate(entry.data.date)}
        </time>
        {
          isHuman ? (
            <span class="meta-pill meta-pill--human">
              Menneskeskrevet{author && <> · {author}</>}
            </span>
          ) : (
            <span class="meta-pill meta-pill--ai">
              KI-generert{author && <> · {author}</>}
            </span>
          )
        }
        {entry.data.tags.map((tag) => <span class="meta-pill">{tag}</span>)}
      </div>
    </section>

    {
      linkedIsiReports.length > 0 && (
        <section class="article-detail__isi" aria-label="ISI-analyser">
          <span class="eyebrow">ISI-analyser</span>
          <div class="article-detail__isi-grid">
            {linkedIsiReports.map((report) => (
              <IsiReportCard report={report} />
            ))}
          </div>
        </section>
      )
    }

    <section class="surface prose article-detail__body">
      <Content />
    </section>

    {
      sources.length > 0 && (
        <section class="article-detail__sources" aria-label="Kilder">
          <span class="eyebrow">Dokumentasjon</span>
          <div class="surface">
            <div>
              <h2>Kilder</h2>
            </div>
            <ul>
              {sources.map((source) => (
                <li>
                  {source.url ? (
                    <a
                      href={source.url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {source.title}
                    </a>
                  ) : (
                    source.title
                  )}
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }
  </article>
</Layout>

<style is:global>
  .article-detail {
    display: grid;
    gap: 1.4rem;
  }

  .article-detail__hero {
    display: grid;
    gap: 1.2rem;
  }

  .article-detail__hero-copy {
    display: grid;
    gap: 0.5rem;
  }

  .article-detail__hero-figure {
    margin: 0;
    border-radius: 0.85rem;
    overflow: hidden;
    display: grid;
    gap: 0.5rem;
  }

  .article-detail__hero-figure figcaption {
    font-size: 0.85rem;
    color: var(--muted);
    font-family: var(--font-sans);
  }

  .article-detail__hero-img {
    width: 100%;
    max-height: 28rem;
    object-fit: cover;
    border-radius: 0.85rem;
    display: block;
  }

  .article-detail__body figure {
    margin: 1.6rem 0;
    display: grid;
    gap: 0.5rem;
  }

  .article-detail__body figure img {
    width: 100%;
    border-radius: 0.65rem;
    display: block;
  }

  .article-detail__body figure figcaption {
    font-size: 0.85rem;
    color: var(--muted);
    font-family: var(--font-sans);
  }

  .article-detail__sources {
    display: grid;
    gap: 1rem;
  }

  .article-detail__isi {
    display: grid;
    gap: 1rem;
  }

  .article-detail__isi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(300px, 100%), 1fr));
    gap: 1.2rem;
  }
</style>
