---
import { getCollection } from "astro:content";
import IsiReportCard from "../components/IsiReportCard.astro";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../lib/seo";

const allReports = await getCollection("isi");
const featured = [...allReports]
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime())
  .slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${SITE.url}/#org`,
      name: SITE.name,
      url: SITE.url,
      description: SITE.description,
      founder: { "@type": "Person", name: SITE.founder },
    },
    {
      "@type": "WebSite",
      "@id": `${SITE.url}/#website`,
      name: SITE.name,
      url: SITE.url,
      publisher: { "@id": `${SITE.url}/#org` },
      inLanguage: "nb",
    },
    {
      "@type": "SiteNavigationElement",
      name: "Manifestet",
      url: `${SITE.url}/manifest/`,
    },
    {
      "@type": "SiteNavigationElement",
      name: "ISI-analyser",
      url: `${SITE.url}/isi/`,
    },
  ],
};
---

<Layout title="Individet — en AI-drevet tenketank">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <header class="masthead">
    <div class="masthead-inner">
      <div class="wordmark">Individet</div>
      <p class="tagline">En AI-drevet tenketank for individets suverenitet</p>
    </div>
  </header>

  <section class="intro">
    <p class="lead">
      Individet er en uavhengig tenketank grunnlagt og drevet av
      <strong>Lars-Erik Bruce</strong>. Vi produserer analytiske rapporter og
      verktøy forankret i ett spørsmål som aldri stilner:
    </p>
    <blockquote>
      <em>Hvem eier deg?</em>
    </blockquote>
    <p>
      Svaret er selvinnlysende — og likevel bestandig omstridt. Vår misjon er å
      hegne om individets suverenitet: retten ethvert menneske har til å eie og
      styre sitt eget liv, uten at noen stat, institusjon eller bevegelse kan
      krenke det uten konsekvens.
    </p>
    <p>
      Tenketanken er AI-drevet. Rapportene produseres med kunstig intelligens
      som analytisk verktøy — men alltid under menneskelig kontroll og med krav
      om faglig kvalitet. Automatiseringen vil økes gradvis, men aldri på
      bekostning av presisjon og etterrettelighet.
    </p>
  </section>

  <hr />

  <section class="products">
    <article class="product-card">
      <h2>Manifestet</h2>
      <p>
        Individets ideologiske grunnlag er formulert i manifestet
        <em>Individets Suverenitet</em>. Det er ikke en partilinje — det er en
        observasjon av virkeligheten. Tråden løper fra Aristoteles og stoikerne,
        gjennom Locke og Bastiat, frem til vår tid: selveierskapet er
        ufravikelig, og tvangens logikk brytes ned uansett hvilke gode
        intensjoner den pakkes inn i.
      </p>
      <a href="/manifest/" class="cta-link">Les manifestet →</a>
    </article>

    <article class="product-card">
      <h2>Individets Suverenitetsindeks (ISI)</h2>
      <p>
        ISI er et analytisk rammeverk som bedømmer samfunnsaktører — politikere,
        partier, organisasjoner og medier — etter én målestokk: fremmer eller
        hemmer de individets suverenitet? Hver aktør scores på tvers av seks
        dimensjoner, fra kroppslig autonomi og ytringsfrihet til eiendomsrett og
        rettsstaten.
      </p>
      <p>
        Karakteren er ikke meningsytring. Den er dokumentert og etterprøvbar —
        forankret i offentlige uttalelser, stemmegivning og vedtatte posisjoner.
      </p>
      <a href="/isi/" class="cta-link">Se alle ISI-analyser →</a>
    </article>
  </section>

  <hr />

  <section class="featured-reports">
    <h2 class="featured-reports__heading">Siste ISI-analyser</h2>
    <ul class="report-list">
      {
        featured.map((report) => (
          <li>
            <IsiReportCard report={report} />
          </li>
        ))
      }
    </ul>
    <p class="featured-reports__cta">
      <a href="/isi/" class="cta-link">Se alle ISI-analyser →</a>
    </p>
  </section>

  <hr />

  <footer class="site-footer">
    <p>
      Individet er startet og drives av <strong>Lars-Erik Bruce</strong>.
      Innhold publiseres fortløpende på <strong>www.individet.no</strong>. <a
        href="/rss.xml"
        class="cta-link">RSS-feed</a
      >.
    </p>
  </footer>
</Layout>

<style>
  .masthead {
    padding: 3rem 0 2rem;
    border-bottom: 2px solid #1f2421;
    margin-bottom: 2.5rem;
  }

  .masthead-inner {
    margin: 0 16px;
  }

  .wordmark {
    font-size: 2.8rem;
    font-weight: bold;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #1f2421;
  }

  .tagline {
    margin: 0.4rem 0 0;
    font-size: 0.95rem;
    color: #555;
    font-style: italic;
  }

  .intro {
    margin-bottom: 2rem;
  }

  .lead {
    font-size: 1.1rem;
    line-height: 1.65;
  }

  blockquote {
    border-left: 3px solid #1f2421;
    margin: 1.5rem 0 1.5rem 0;
    padding: 0.5rem 1.2rem;
    font-size: 1.3rem;
    color: #1f2421;
  }

  hr {
    border: none;
    border-top: 1px solid #d6d3cc;
    margin: 2.5rem 16px;
  }

  .products {
    display: grid;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 660px) {
    .products {
      grid-template-columns: 1fr 1fr;
    }
  }

  .product-card {
    border: 1px solid #d6d3cc;
    border-radius: 2px;
    padding: 1.4rem 1.6rem;
    background: #fff;
  }

  .product-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
  }

  .product-card p {
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .cta-link {
    font-size: 0.9rem;
    font-weight: bold;
    text-decoration: none;
    color: #274c77;
  }

  .cta-link:hover {
    text-decoration: underline;
  }

  .site-footer {
    color: #555;
    font-size: 0.9rem;
    margin-bottom: 3rem;
  }

  .featured-reports__heading {
    font-size: 1.1rem;
    margin: 0 0 1rem;
  }

  .featured-reports__cta {
    margin-top: 1rem;
    text-align: right;
  }

  .report-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .report-list li {
    box-shadow: 0 6px 18px rgba(31, 36, 33, 0.05);
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .report-list li:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px rgba(31, 36, 33, 0.1);
  }
</style>
