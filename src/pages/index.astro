---
import { getCollection } from 'astro:content'
import Icon from '../components/Icon.astro'
import IsiReportCard from '../components/IsiReportCard.astro'
import Layout from '../layouts/Layout.astro'
import { SITE } from '../lib/seo'

const allReports = await getCollection('isi')
const featured = [...allReports]
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime())
  .slice(0, 3)

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE.url}/#org`,
      name: SITE.name,
      url: SITE.url,
      sameAs: [SITE.facebookUrl],
      description: SITE.description,
      founder: { '@type': 'Person', name: SITE.founder },
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}/#website`,
      name: SITE.name,
      url: SITE.url,
      publisher: { '@id': `${SITE.url}/#org` },
      inLanguage: 'nb',
    },
    {
      '@type': 'SiteNavigationElement',
      name: 'Manifestet',
      url: `${SITE.url}/manifest/`,
    },
    {
      '@type': 'SiteNavigationElement',
      name: 'ISI-analyser',
      url: `${SITE.url}/isi/`,
    },
    {
      '@type': 'SiteNavigationElement',
      name: 'Om Individet',
      url: `${SITE.url}/om/`,
    },
  ],
}
---

<Layout title="Individet — en AI-drevet tankesmie">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <div class="home-shell">
    <section class="page-hero home-hero">
      <div class="home-hero__content">
        <span class="eyebrow">Tankesmien Individet</span>
        <h1 class="page-hero__title">
          En frihetsorientert tankesmie med profesjonell presisjon.
        </h1>

        <div class="meta-strip">
          <span class="meta-pill">Uavhengig</span>
          <span class="meta-pill">AI-drevet</span>
          <span class="meta-pill">Åpent metodegrunnlag</span>
        </div>

        <div class="button-row">
          <a href="/manifest/" class="button-link">Les manifestet</a>
          <a href="/isi/" class="button-link">Utforsk ISI-analysene</a>
        </div>
      </div>

      <aside class="home-hero__panel surface">
        <p class="home-hero__panel-label">Vårt utgangspunkt</p>
        <blockquote class="home-hero__quote">
          <em>Ingen stat eller institusjon eier mennesket.</em>
        </blockquote>
        <p>
          Derfor kombinerer Individet idéarbeid, måling og dokumentasjon i ett
          felles prosjekt: å tydeliggjøre hvor individets frihet blir styrket og
          hvor den blir innsnevret.
        </p>
        <hr class="hr-white" />
        <p>
          Individet er en AI-drevet tankesmie for individets suverenitet. Vi
          utvikler analyser, manifest og åpne verktøy som undersøker ett
          grunnspørsmål uten å vike: <strong>Hvem eier deg?</strong>
        </p>
      </aside>
    </section>

    <section class="home-principles">
      <article class="surface principle-card">
        <span class="eyebrow">Suverenitet</span>
        <h2>Frihet som første prinsipp</h2>
        <p>
          Vi tar utgangspunkt i selveierskap, frivillighet og rettsstatlige
          grenser for maktutøvelse.
        </p>
      </article>

      <article class="surface principle-card">
        <span class="eyebrow">Etterrettelighet</span>
        <h2>Analyse fremfor støy</h2>
        <p>
          Påstander skal kunne spores. Poeng, vurderinger og klassifiseringer må
          være lesbare, begrunnede og kritiserbare.
        </p>
      </article>

      <article class="surface principle-card">
        <span class="eyebrow">Åpen prosess</span>
        <h2>Maskineriet er synlig</h2>
        <p>
          Arbeidet skjer i en åpen prosess der verktøy, kode og metode kan
          granskes uten innsideadgang.
        </p>
      </article>
    </section>

    <section class="home-focus">
      <article class="surface focus-card">
        <span class="eyebrow">Manifestet</span>
        <h2>Et idégrunnlag uten kollektiv tåke</h2>
        <p>
          <em>Individets Suverenitet</em> samler tankesmiens normative grunnlag: mennesket
          eier seg selv, og tvang mister ikke sin natur selv om den kles i gode hensikter.
        </p>
        <a href="/manifest/" class="button-link">Gå til manifestet</a>
      </article>

      <article class="surface focus-card focus-card--accent">
        <span class="eyebrow">ISI</span>
        <h2>Et rammeverk for å måle hvem som styrker friheten</h2>
        <p>
          Individets Suverenitetsindeks vurderer politikere, medier,
          organisasjoner og partier på tvers av seks dimensjoner av frihetsvern.
        </p>
        <a href="/isi/" class="button-link">Se alle analyser</a>
      </article>
    </section>

    <section class="home-featured surface">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Nye analyser</span>
          <h2>Siste publiserte ISI-vurderinger</h2>
        </div>
        <a href="/isi/" class="button-link button-link--secondary">
          Hele oversikten
        </a>
      </div>

      <ul class="report-list">
        {
          featured.map((report) => (
            <li>
              <IsiReportCard report={report} />
            </li>
          ))
        }
      </ul>
    </section>

    <section class="surface open-process">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Åpenhet</span>
          <h2>Maskineriet som driver nettstedet kan granskes</h2>
        </div>
      </div>

      <p>
        Innholdet på nettstedet er drevet av koden som befinner seg i
        <a href={SITE.githubUrl} target="_blank" rel="noopener noreferrer">
          Individet/tankesmia <Icon name="arrow-up-right" size={14} />
        </a>. Her finner du kode, agent-oppsett og arbeidsflyt som brukes til å
        drifte tankesmien.
      </p>
    </section>
  </div>
</Layout>

<style>
  .home-shell {
    display: grid;
    gap: 1.2rem;
  }

  .home-hero {
    grid-template-columns: minmax(0, 1.5fr) minmax(18rem, 0.9fr);
    align-items: stretch;
  }

  .home-hero__content {
    display: grid;
    align-content: center;
    gap: 1rem;
  }

  .home-hero__panel {
    display: grid;
    align-content: start;
    gap: 0.85rem;
    background:
      linear-gradient(180deg, rgba(15, 32, 48, 0.96), rgba(24, 54, 75, 0.92)),
      var(--bg-deep);
    color: rgba(247, 241, 227, 0.9);
    border-color: rgba(247, 241, 227, 0.12);
  }

  .home-hero__panel strong {
    color: rgba(247, 241, 227, 0.9);
  }

  .home-hero__panel-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(241, 230, 199, 0.74);
  }

  .home-hero__quote {
    margin: 0;
    padding-left: 1rem;
    border-left: 2px solid rgba(241, 230, 199, 0.32);
    font-size: 1.3rem;
    line-height: 1.4;
    color: #fff;
  }

  .home-principles,
  .home-focus {
    display: grid;
    gap: 0.9rem;
  }

  .principle-card,
  .focus-card {
    display: grid;
    gap: 0.65rem;
  }

  .focus-card {
    grid-template-rows: auto auto minmax(0, 1fr) auto;
  }

  .principle-card h2,
  .focus-card h2,
  .home-featured h2,
  .open-process h2 {
    font-size: clamp(1.35rem, 2vw, 1.9rem);
  }

  .focus-card--accent {
    background:
      radial-gradient(
        circle at top right,
        rgba(185, 148, 83, 0.16),
        transparent 28%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.96),
        rgba(246, 239, 226, 0.88)
      );
  }

  .home-featured,
  .open-process {
    display: grid;
    gap: 0.9rem;
  }

  .report-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.95rem;
  }

  .report-list li {
    min-width: 0;
  }

  @media (min-width: 760px) {
    .home-principles {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .home-focus {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 940px) {
    .home-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
