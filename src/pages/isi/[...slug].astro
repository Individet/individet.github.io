---
import ActorPortrait from '../../components/ActorPortrait.astro'
import { getCollection, render } from 'astro:content'
import Icon from '../../components/Icon.astro'
import IsiScorecard from '../../components/IsiScorecard.astro'
import IsiScoreRing from '../../components/IsiScoreRing.astro'
import { getActorPortrait } from '../../lib/actorPortraits'
import Layout from '../../layouts/Layout.astro'
import { getIsiClass, getIsiScore, getIsiRawScore } from '../../lib/isi'

export async function getStaticPaths() {
  const reports = await getCollection('isi')

  return reports.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const rawScore = getIsiRawScore(entry)
const isiScore = getIsiScore(entry)
const isiClass = getIsiClass(entry)
const tags = entry.data.tags ?? []
const primarySources = entry.data.primarySources ?? []
const secondarySources = entry.data.secondarySources ?? []
const portrait = getActorPortrait(entry.data.actorSlug, entry.data.actorName)
const socialImage =
  portrait.kind === 'image' ? portrait.src : '/social/isi-fallback.png'
---

<Layout
  title={`${entry.data.actorName} | ISI | Individet`}
  description={`ISI-analyse av ${entry.data.actorName}: score ${isiScore}, klassifisering ${isiClass}. Vurdert etter individets suverenitetsindeks.`}
  ogType="article"
  ogImage={socialImage}
  ogImageAlt={`Forhåndsvisningsbilde for ISI-analysen av ${entry.data.actorName}`}
>
  <article class="isi-report">
    <div class="meta-strip">
      <a href="/isi/" class="button-link button-link--secondary">
        Til ISI-oversikten
      </a>
    </div>

    <section class="page-hero isi-report__hero">
      <figure class="isi-report__portrait">
        <ActorPortrait portrait={portrait} size="detail" />
        <figcaption>
          {
            portrait.kind === 'image' ? (
              <>
                <span>Foto: {portrait.author || portrait.source}</span>
                {portrait.license && (
                  <>
                    {' '}
                    ·{' '}
                    {portrait.licenseUrl ? (
                      <a
                        href={portrait.licenseUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {portrait.license}
                      </a>
                    ) : (
                      portrait.license
                    )}
                  </>
                )}
                {portrait.sourcePageUrl && (
                  <>
                    {' '}
                    ·{' '}
                    <a
                      href={portrait.sourcePageUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Kildeside <Icon name="arrow-up-right" size={14} />
                    </a>
                  </>
                )}
              </>
            ) : (
              <span />
            )
          }
        </figcaption>
      </figure>

      <div class="isi-report__hero-copy">
        <span class="eyebrow">ISI-analyse</span>
        <h1 class="page-hero__title">{entry.data.actorName}</h1>
        <p class="page-hero__lede">
          {entry.data.actorType} · {entry.data.actorAffiliation}
        </p>

        <div class="isi-report__summary-grid">
          <article class="surface isi-report__summary-card">
            <span class="eyebrow">ISI-score</span>
            <div class="isi-report__score-line">
              <h2>{isiScore}</h2>
              <IsiScoreRing
                score={isiScore}
                showValue={false}
                size={54}
                label={`ISI-score ${isiScore}`}
              />
            </div>
            <p>Råskår {rawScore}</p>
          </article>

          <article class="surface isi-report__summary-card">
            <span class="eyebrow">Klassifisering</span>
            <h2>{isiClass}</h2>
            <p>Basert på seks dimensjoner av individets suverenitet.</p>
          </article>
        </div>

        <div class="meta-strip">
          <span class="meta-pill"
            >Analysert data: {entry.data.analysisScope}</span
          >
          <span class="meta-pill">
            Sist oppdatert: {entry.data.lastUpdated.toISOString().slice(0, 10)}
          </span>
          <span class="meta-pill">Land: {entry.data.actorCountry}</span>
        </div>
      </div>
    </section>

    {
      tags.length > 0 && (
        <section class="surface isi-report__tags" aria-label="Tagger">
          <p class="isi-report__tags-label">Tagger</p>
          <ul class="isi-report__tag-list">
            {tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        </section>
      )
    }
    <section class="surface prose prose--wide">
      <Content />
    </section>
    <section
      id="isi-scorecard-runtime"
      class="isi-scorecard-runtime surface"
      hidden
    >
      <IsiScorecard data={entry.data} rawScore={rawScore} isiScore={isiScore} />
    </section>
    <section class="isi-report__sources" aria-label="Kilder">
      <div class="section-heading">
        <div>
          <span class="eyebrow">Dokumentasjon</span>
          <h2>Kilder</h2>
        </div>
      </div>
      <div class="isi-report__source-grid">
        <section class="surface isi-report__panel">
          <h3>Primærkilder</h3>
          {
            primarySources.length === 0 ? (
              <p class="isi-report__empty">Ingen primærkilder registrert.</p>
            ) : (
              <ul>
                {primarySources.map((source) => (
                  <li>{source}</li>
                ))}
              </ul>
            )
          }
        </section>

        <section class="surface isi-report__panel">
          <h3>Sekundærkilder</h3>
          {
            secondarySources.length === 0 ? (
              <p class="isi-report__empty">Ingen sekundærkilder registrert.</p>
            ) : (
              <ul>
                {secondarySources.map((source) => (
                  <li>{source}</li>
                ))}
              </ul>
            )
          }
        </section>
      </div>
    </section>
  </article>
</Layout>

<script is:inline>
  const article = document.querySelector('.isi-report')
  const runtimeScorecard = document.getElementById('isi-scorecard-runtime')
  const scoreHeading = article?.querySelector('h3[id="skårtabell"]')

  if (article && runtimeScorecard && scoreHeading) {
    let current = scoreHeading.nextElementSibling

    while (current && !/^H[1-3]$/.test(current.tagName)) {
      const next = current.nextElementSibling
      current.remove()
      current = next
    }

    runtimeScorecard.hidden = false
    scoreHeading.after(runtimeScorecard)
  }
</script>

<style is:global>
  .isi-report {
    display: grid;
    gap: 1.4rem;
  }

  .isi-report__hero {
    grid-template-columns: minmax(15rem, 19rem) minmax(0, 1fr);
    gap: 1.4rem;
    align-items: start;
  }

  .isi-report__portrait {
    margin: 0;
    display: grid;
    gap: 0.55rem;
    justify-items: start;
  }

  .isi-report__portrait figcaption {
    font-size: 0.88rem;
    color: var(--muted);
  }

  .isi-report__hero-copy {
    display: grid;
    gap: 1rem;
  }

  .isi-report__summary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .isi-report__summary-card {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .isi-report__summary-card h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    overflow-wrap: anywhere;
  }

  .isi-report__score-line {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .isi-report .isi-scorecard {
    display: grid;
    gap: 1rem;
    margin: 0;
  }

  .isi-report .isi-scorecard__summary,
  .isi-report .isi-scorecard__panel {
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .isi-report .isi-scorecard__summary {
    padding: 0;
  }

  .isi-report .isi-scorecard__metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem;
    margin: 0;
  }

  .isi-report .isi-scorecard__metric {
    padding: 0.9rem 1rem;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid var(--line);
    border-radius: 1.2rem;
  }

  .isi-report .isi-scorecard__metric dt {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .isi-report .isi-scorecard__metric dd {
    margin: 0.35rem 0 0;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.15;
  }

  .isi-report .isi-scorecard__metric dd span {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--muted);
  }

  .isi-report .isi-scorecard__panel {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.56);
  }

  .isi-report .isi-scorecard__panel h4 {
    margin: 0;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--line);
    background: rgba(52, 86, 101, 0.08);
  }

  .isi-report .isi-scorecard__panel p,
  .isi-report .isi-scorecard__panel ul {
    margin: 0;
  }

  .isi-report .isi-scorecard__panel p,
  .isi-report .isi-scorecard__panel ul,
  .isi-report .isi-scorecard__panel table {
    width: 100%;
  }

  .isi-report .isi-scorecard__panel p {
    padding: 1rem;
  }

  .isi-report .isi-scorecard__panel table {
    border-collapse: collapse;
  }

  .isi-report .isi-scorecard__panel th,
  .isi-report .isi-scorecard__panel td {
    padding: 0.8rem 1rem;
    vertical-align: top;
    border-bottom: 1px solid rgba(31, 36, 33, 0.1);
  }

  .isi-report .isi-scorecard__panel tbody tr:last-child th,
  .isi-report .isi-scorecard__panel tbody tr:last-child td {
    border-bottom: 0;
  }

  .isi-report .isi-scorecard__panel thead th {
    background: rgba(52, 86, 101, 0.08);
    text-align: left;
  }

  .isi-report .isi-scorecard__dimension-row th,
  .isi-report .isi-scorecard__dimension-row td {
    font-weight: 700;
    background: rgba(185, 148, 83, 0.1);
  }

  .isi-report .isi-scorecard__score {
    white-space: nowrap;
    font-weight: 700;
    text-align: right;
  }

  .isi-report .isi-scorecard__subdimension {
    padding-left: 2rem;
  }

  .isi-report__tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding: 0;
    margin: 0;
  }

  .isi-report__tags {
    display: grid;
    gap: 0.5rem;
  }

  .isi-report__tags-label {
    margin: 0;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 700;
  }

  .isi-report__tag-list li {
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid var(--line);
    font-size: 0.95rem;
  }

  .isi-report__sources {
    display: grid;
    gap: 1rem;
    margin-top: 0;
  }

  .isi-scorecard-runtime[hidden] {
    display: none !important;
  }

  .isi-report__source-grid {
    display: grid;
    gap: 1rem;
  }

  .isi-report__panel {
    overflow: hidden;
  }

  .isi-report__panel h3 {
    margin: 0;
    padding: 0 0 0.8rem;
    border-bottom: 1px solid var(--line);
  }

  .isi-report__panel p,
  .isi-report__panel ul {
    margin: 0;
  }

  .isi-report__panel p {
    padding: 1rem 0 0;
  }

  .isi-report__panel ul {
    padding: 1rem 0 0 1.3rem;
  }

  .isi-report__panel li + li {
    margin-top: 0.55rem;
  }

  .isi-report__empty {
    color: var(--muted);
  }

  @media (min-width: 760px) {
    .isi-report__source-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 920px) {
    .isi-report__hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .isi-report__summary-grid {
      grid-template-columns: 1fr;
    }

    .isi-report .isi-scorecard__panel th,
    .isi-report .isi-scorecard__panel td {
      padding: 0.7rem 0.8rem;
    }

    .isi-report .isi-scorecard__subdimension {
      padding-left: 1.2rem;
    }
  }
</style>
