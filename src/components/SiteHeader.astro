---
const { currentPath = '/' } = Astro.props

const navigation = [
  { href: '/', label: 'Forside' },
  { href: '/manifest/', label: 'Manifest' },
  { href: '/isi/', label: 'ISI-analyser' },
  { href: '/om/', label: 'Om Individet' },
]

function isActive(href: string) {
  if (href === '/') return currentPath === '/'
  return currentPath === href || currentPath.startsWith(href)
}
---

<header class="site-header">
  <a class="skip-link" href="#main-content">Hopp til innhold</a>

  <div class="site-header__inner">
    <a href="/" class="site-logo">
      <img
        src="/logo.svg"
        alt=""
        class="site-logo__mark"
        width="36"
        height="36"
        aria-hidden="true"
      />
      <span class="site-logo__wordmark">Individet</span>
      <span class="site-logo__tagline"
        >Frihet · Presisjon · Etterrettelighet</span
      >
    </a>

    <nav class="site-nav" aria-label="Hovednavigasjon">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              'site-nav__link',
              { 'is-active': isActive(item.href) },
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--ivory);
    border-bottom: 1px solid var(--rule-light);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1120px;
    margin: 0 auto;
    padding: 1rem 2rem;
  }

  .site-logo {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
  }

  .site-logo__mark {
    display: block;
    flex-shrink: 0;
  }

  .site-logo:hover {
    text-decoration: none;
    color: inherit;
  }

  .site-logo__wordmark {
    font-family: var(--f-display);
    font-weight: 600;
    font-size: 1.7rem;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1;
  }

  .site-logo__tagline {
    font-family: var(--f-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-top: 2px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .site-nav__link {
    font-family: var(--f-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    padding: 0.5rem 1.1rem;
    border-right: 1px solid var(--rule-light);
    text-decoration: none;
    transition:
      color 0.2s,
      background 0.2s;
  }

  .site-nav__link:first-child {
    border-left: 1px solid var(--rule-light);
  }

  .site-nav__link:hover {
    color: var(--terracotta);
    background: var(--parchment);
    text-decoration: none;
  }

  .site-nav__link.is-active {
    color: var(--terracotta);
    font-weight: 700;
  }

  @media (max-width: 860px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.85rem 1.25rem;
    }

    .site-nav {
      flex-wrap: wrap;
    }

    .site-nav__link {
      padding: 0.5rem 0.8rem;
      font-size: 0.72rem;
    }
  }
</style>
