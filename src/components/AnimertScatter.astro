---
type YKey = 'gdp' | 'gdp_real' | 'le' | 'cm' | 'whr_happiness'
type XKey =
  | 'hs'
  | 'hs_prop_rights'
  | 'hs_gov_integrity'
  | 'hs_judicial'
  | 'hs_tax_burden'
  | 'hs_gov_spending'
  | 'hs_fiscal_health'
  | 'hs_business'
  | 'hs_labor'
  | 'hs_monetary'
  | 'hs_trade'
  | 'hs_investment'
  | 'hs_financial'
  | 'hf_score'
  | 'pf_score'
  | 'ef_hfi'
  | 'pf_expression'
  | 'pf_assembly'
  | 'pf_rol'

interface Props {
  defaultXKey?: XKey
  defaultYKey?: YKey
  allowAxisChange?: boolean
}

const {
  defaultXKey = 'hs',
  defaultYKey = 'gdp_real',
  allowAxisChange = true,
} = Astro.props

const Y_LABEL_MAP: Record<string, string> = {
  gdp_real: 'BNP per capita (inflasjonsjustert)',
  gdp: 'BNP per capita (løpende)',
  le: 'Forventet levealder',
  cm: 'Barnedødelighet',
  whr_happiness: 'Livstilfredshet (WHR)',
}

const X_LABEL_MAP: Record<string, string> = {
  hs: 'Heritage – Samlet',
  hs_prop_rights: 'Eiendomsrettigheter',
  hs_gov_integrity: 'Regjeringens integritet',
  hs_judicial: 'Rettsstatens effektivitet',
  hs_tax_burden: 'Skattetrykk',
  hs_gov_spending: 'Offentlige utgifter',
  hs_fiscal_health: 'Finansiell helse',
  hs_business: 'Næringslivsfrihet',
  hs_labor: 'Arbeidsmarkedsfrihet',
  hs_monetary: 'Monetær frihet',
  hs_trade: 'Handelsfrihet',
  hs_investment: 'Investeringsfrihet',
  hs_financial: 'Finansiell frihet',
  hf_score: 'Menneskelig frihet (HFI)',
  pf_score: 'Personlig frihet (HFI)',
  ef_hfi: 'Økonomisk frihet (Fraser/HFI)',
  pf_expression: 'Ytringsfrihet (HFI)',
  pf_assembly: 'Forsamlingsfrihet (HFI)',
  pf_rol: 'Rettsstaten (HFI)',
}
---

<section class="section">
  {
    allowAxisChange ? (
      <Fragment>
        <div class="y-selector">
          <span class="y-selector-label">Y-akse:</span>
          <div role="group" aria-label="Velg Y-akse">
            <button
              type="button"
              class:list={['y-btn', { active: defaultYKey === 'gdp_real' }]}
              data-ykey="gdp_real"
            >
              BNP per capita (inflasjonsjustert)
            </button>
            <button
              type="button"
              class:list={['y-btn', { active: defaultYKey === 'gdp' }]}
              data-ykey="gdp"
            >
              BNP per capita (løpende)
            </button>
            <button
              type="button"
              class:list={['y-btn', { active: defaultYKey === 'le' }]}
              data-ykey="le"
            >
              Forventet levealder
            </button>
            <button
              type="button"
              class:list={['y-btn', { active: defaultYKey === 'cm' }]}
              data-ykey="cm"
            >
              Barnedødelighet
            </button>
            <button
              type="button"
              class:list={[
                'y-btn',
                { active: defaultYKey === 'whr_happiness' },
              ]}
              data-ykey="whr_happiness"
            >
              Livstilfredshet (WHR)
            </button>
          </div>
        </div>
        <div class="x-selector">
          <span class="x-selector-label">X-akse:</span>
          <select class="x-select" aria-label="Velg X-akse">
            <optgroup label="Heritage: Samlet">
              <option value="hs" selected={defaultXKey === 'hs'}>
                Heritage – Samlet
              </option>
            </optgroup>
            <optgroup label="Heritage: Rettsstat og styresett">
              <option
                value="hs_prop_rights"
                selected={defaultXKey === 'hs_prop_rights'}
              >
                Eiendomsrettigheter
              </option>
              <option
                value="hs_gov_integrity"
                selected={defaultXKey === 'hs_gov_integrity'}
              >
                Regjeringens integritet
              </option>
              <option
                value="hs_judicial"
                selected={defaultXKey === 'hs_judicial'}
              >
                Rettsstatens effektivitet
              </option>
            </optgroup>
            <optgroup label="Heritage: Finanspolitikk">
              <option
                value="hs_tax_burden"
                selected={defaultXKey === 'hs_tax_burden'}
              >
                Skattetrykk
              </option>
              <option
                value="hs_gov_spending"
                selected={defaultXKey === 'hs_gov_spending'}
              >
                Offentlige utgifter
              </option>
              <option
                value="hs_fiscal_health"
                selected={defaultXKey === 'hs_fiscal_health'}
              >
                Finansiell helse
              </option>
            </optgroup>
            <optgroup label="Heritage: Regulatorisk frihet">
              <option
                value="hs_business"
                selected={defaultXKey === 'hs_business'}
              >
                Næringslivsfrihet
              </option>
              <option value="hs_labor" selected={defaultXKey === 'hs_labor'}>
                Arbeidsmarkedsfrihet
              </option>
              <option
                value="hs_monetary"
                selected={defaultXKey === 'hs_monetary'}
              >
                Monetær frihet
              </option>
            </optgroup>
            <optgroup label="Heritage: Åpen økonomi">
              <option value="hs_trade" selected={defaultXKey === 'hs_trade'}>
                Handelsfrihet
              </option>
              <option
                value="hs_investment"
                selected={defaultXKey === 'hs_investment'}
              >
                Investeringsfrihet
              </option>
              <option
                value="hs_financial"
                selected={defaultXKey === 'hs_financial'}
              >
                Finansiell frihet
              </option>
            </optgroup>
            <optgroup label="Cato/Fraser: Human Freedom Index">
              <option value="hf_score" selected={defaultXKey === 'hf_score'}>
                Menneskelig frihet (HFI)
              </option>
              <option value="pf_score" selected={defaultXKey === 'pf_score'}>
                Personlig frihet (HFI)
              </option>
              <option value="ef_hfi" selected={defaultXKey === 'ef_hfi'}>
                Økonomisk frihet (Fraser/HFI)
              </option>
              <option
                value="pf_expression"
                selected={defaultXKey === 'pf_expression'}
              >
                Ytringsfrihet (HFI)
              </option>
              <option
                value="pf_assembly"
                selected={defaultXKey === 'pf_assembly'}
              >
                Forsamlingsfrihet (HFI)
              </option>
              <option value="pf_rol" selected={defaultXKey === 'pf_rol'}>
                Rettsstaten (HFI)
              </option>
            </optgroup>
          </select>
        </div>
      </Fragment>
    ) : (
      <div class="axis-info">
        <span class="axis-info-item">
          <span class="axis-info-label">Y-akse:</span>
          {Y_LABEL_MAP[defaultYKey]}
        </span>
        <span class="axis-info-item">
          <span class="axis-info-label">X-akse:</span>
          {X_LABEL_MAP[defaultXKey]}
        </span>
      </div>
    )
  }
  <div class="scatter-controls">
    <button class="play-btn" type="button" aria-label="Spill av / pause">
      <span class="play-icon">▶</span>
      <span class="play-label">Spill av</span>
    </button>
    <span class="year-display" aria-live="polite">1995</span>
    <input
      type="range"
      min="1995"
      max="2026"
      value="1995"
      step="1"
      aria-label="Velg år"
      class="year-slider"
    />
  </div>

  <div class="chart-scroll">
    <div
      class="scatter-chart chart-container"
      data-default-x={defaultXKey}
      data-default-y={defaultYKey}
    >
    </div>
  </div>

  <div class="scatter-legend"></div>
</section>

<script>
  import * as d3 from 'd3'

  // ─── Typer ──────────────────────────────────────────────────────────────────

  interface ScatterEntry {
    iso3: string
    name: string
    hs: number
    // Heritage sub-pillars
    hs_prop_rights?: number
    hs_gov_integrity?: number
    hs_judicial?: number
    hs_tax_burden?: number
    hs_gov_spending?: number
    hs_fiscal_health?: number
    hs_business?: number
    hs_labor?: number
    hs_monetary?: number
    hs_trade?: number
    hs_investment?: number
    hs_financial?: number
    // HFI per-year
    hf_score?: number
    pf_score?: number
    ef_hfi?: number
    pf_expression?: number
    pf_assembly?: number
    pf_rol?: number
    // World Bank
    gdp: number
    gdp_real?: number
    le?: number
    cm?: number
    // World Happiness Report
    whr_happiness?: number
    region: string
  }

  interface ScatterTs {
    years: number[]
    byYear: Record<string, ScatterEntry[]>
  }

  type YKey = 'gdp' | 'gdp_real' | 'le' | 'cm' | 'whr_happiness'

  interface YConfig {
    axisLabel: string
    scaleType: 'log' | 'linear'
    domain: [number, number]
    tickFormat: (d: { valueOf(): number }) => string
    ticks: number
    tooltipFn: (d: ScatterEntry) => string
  }

  const Y_CONFIGS: Record<YKey, YConfig> = {
    gdp_real: {
      axisLabel: '↑ BNP per capita, PPP, faste 2021-USD',
      scaleType: 'log',
      domain: [600, 160000],
      tickFormat: (d) => `$${d3.format('.2s')(+d)}`,
      ticks: 6,
      tooltipFn: (d) =>
        d.gdp_real != null
          ? `BNP (fast): $${d.gdp_real.toLocaleString('nb-NO')}`
          : '–',
    },
    gdp: {
      axisLabel: '↑ BNP per capita, PPP (USD)',
      scaleType: 'log',
      domain: [600, 160000],
      tickFormat: (d) => `$${d3.format('.2s')(+d)}`,
      ticks: 6,
      tooltipFn: (d) => `BNP: $${d.gdp.toLocaleString('nb-NO')}`,
    },
    le: {
      axisLabel: '↑ Forventet levealder (år)',
      scaleType: 'linear',
      domain: [20, 90],
      tickFormat: (d) => `${(+d).toFixed(0)} år`,
      ticks: 7,
      tooltipFn: (d) =>
        d.le != null ? `Levealder: ${d.le.toFixed(1)} år` : '–',
    },
    cm: {
      axisLabel: '↑ Barnedødelighet (per 1 000)',
      scaleType: 'log',
      domain: [1, 300],
      tickFormat: (d) => `${(+d).toFixed(0)}‰`,
      ticks: 5,
      tooltipFn: (d) =>
        d.cm != null ? `Barnedødelighet: ${d.cm.toFixed(1)} ‰` : '–',
    },
    whr_happiness: {
      axisLabel: '↑ Livstilfredshet, 0–10 (WHR)',
      scaleType: 'linear',
      domain: [1, 9],
      tickFormat: (d) => `${(+d).toFixed(1)}`,
      ticks: 8,
      tooltipFn: (d) =>
        d.whr_happiness != null
          ? `Livstilfredshet: ${d.whr_happiness.toFixed(3)}`
          : '–',
    },
  }

  function getY(d: ScatterEntry, key: YKey): number | null {
    if (key === 'gdp') return d.gdp
    if (key === 'gdp_real') return d.gdp_real ?? null
    if (key === 'le') return d.le ?? null
    if (key === 'cm') return d.cm ?? null
    return d.whr_happiness ?? null
  }

  type XKey =
    | 'hs'
    | 'hs_prop_rights'
    | 'hs_gov_integrity'
    | 'hs_judicial'
    | 'hs_tax_burden'
    | 'hs_gov_spending'
    | 'hs_fiscal_health'
    | 'hs_business'
    | 'hs_labor'
    | 'hs_monetary'
    | 'hs_trade'
    | 'hs_investment'
    | 'hs_financial'
    | 'hf_score'
    | 'pf_score'
    | 'ef_hfi'
    | 'pf_expression'
    | 'pf_assembly'
    | 'pf_rol'

  interface XConfig {
    axisLabel: string
    domain: [number, number]
    tooltipFn: (d: ScatterEntry) => string
  }

  const X_CONFIGS: Record<XKey, XConfig> = {
    hs: {
      axisLabel: 'Heritage Økonomisk frihet (0–100) →',
      domain: [0, 100],
      tooltipFn: (d) => `Heritage: ${d.hs}`,
    },
    hs_prop_rights: {
      axisLabel: 'Heritage: Eiendomsrettigheter →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_prop_rights != null
          ? `Eiendomsrettigheter: ${d.hs_prop_rights}`
          : '–',
    },
    hs_gov_integrity: {
      axisLabel: 'Heritage: Governmenets integritet →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_gov_integrity != null
          ? `Regjeringens integritet: ${d.hs_gov_integrity}`
          : '–',
    },
    hs_judicial: {
      axisLabel: 'Heritage: Rettsstatens effektivitet →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_judicial != null ? `Rettssystem: ${d.hs_judicial}` : '–',
    },
    hs_tax_burden: {
      axisLabel: 'Heritage: Skattetrykk →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_tax_burden != null ? `Skattetrykk: ${d.hs_tax_burden}` : '–',
    },
    hs_gov_spending: {
      axisLabel: 'Heritage: Offentlige utgifter →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_gov_spending != null
          ? `Offentlige utgifter: ${d.hs_gov_spending}`
          : '–',
    },
    hs_fiscal_health: {
      axisLabel: 'Heritage: Finansiell helse →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_fiscal_health != null
          ? `Finansiell helse: ${d.hs_fiscal_health}`
          : '–',
    },
    hs_business: {
      axisLabel: 'Heritage: Næringslivsfrihet →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_business != null ? `Næringslivsfrihet: ${d.hs_business}` : '–',
    },
    hs_labor: {
      axisLabel: 'Heritage: Arbeidsmarkedsfrihet →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_labor != null ? `Arbeidsmarkedsfrihet: ${d.hs_labor}` : '–',
    },
    hs_monetary: {
      axisLabel: 'Heritage: Monetær frihet →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_monetary != null ? `Monetær frihet: ${d.hs_monetary}` : '–',
    },
    hs_trade: {
      axisLabel: 'Heritage: Handelsfrihet →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_trade != null ? `Handelsfrihet: ${d.hs_trade}` : '–',
    },
    hs_investment: {
      axisLabel: 'Heritage: Investeringsfrihet →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_investment != null
          ? `Investeringsfrihet: ${d.hs_investment}`
          : '–',
    },
    hs_financial: {
      axisLabel: 'Heritage: Finansiell frihet →',
      domain: [0, 100],
      tooltipFn: (d) =>
        d.hs_financial != null ? `Finansiell frihet: ${d.hs_financial}` : '–',
    },
    hf_score: {
      axisLabel: 'HFI: Menneskelig frihet (0–10) →',
      domain: [3, 10],
      tooltipFn: (d) =>
        d.hf_score != null
          ? `Menneskelig frihet: ${d.hf_score.toFixed(2)}`
          : '–',
    },
    pf_score: {
      axisLabel: 'HFI: Personlig frihet (0–10) →',
      domain: [2, 10],
      tooltipFn: (d) =>
        d.pf_score != null ? `Personlig frihet: ${d.pf_score.toFixed(2)}` : '–',
    },
    ef_hfi: {
      axisLabel: 'HFI/Fraser: Økonomisk frihet (0–10) →',
      domain: [3, 10],
      tooltipFn: (d) =>
        d.ef_hfi != null ? `Øk. frihet (Fraser): ${d.ef_hfi.toFixed(2)}` : '–',
    },
    pf_expression: {
      axisLabel: 'HFI: Ytringsfrihet (0–10) →',
      domain: [1, 10],
      tooltipFn: (d) =>
        d.pf_expression != null
          ? `Ytringsfrihet: ${d.pf_expression.toFixed(2)}`
          : '–',
    },
    pf_assembly: {
      axisLabel: 'HFI: Forsamlingsfrihet (0–10) →',
      domain: [1, 10],
      tooltipFn: (d) =>
        d.pf_assembly != null
          ? `Forsamlingsfrihet: ${d.pf_assembly.toFixed(2)}`
          : '–',
    },
    pf_rol: {
      axisLabel: 'HFI: Rettsstaten (0–10) →',
      domain: [1, 10],
      tooltipFn: (d) =>
        d.pf_rol != null ? `Rettsstaten: ${d.pf_rol.toFixed(2)}` : '–',
    },
  }

  function getX(d: ScatterEntry, key: XKey): number | null {
    if (key === 'hs') return d.hs
    if (key === 'hs_prop_rights') return d.hs_prop_rights ?? null
    if (key === 'hs_gov_integrity') return d.hs_gov_integrity ?? null
    if (key === 'hs_judicial') return d.hs_judicial ?? null
    if (key === 'hs_tax_burden') return d.hs_tax_burden ?? null
    if (key === 'hs_gov_spending') return d.hs_gov_spending ?? null
    if (key === 'hs_fiscal_health') return d.hs_fiscal_health ?? null
    if (key === 'hs_business') return d.hs_business ?? null
    if (key === 'hs_labor') return d.hs_labor ?? null
    if (key === 'hs_monetary') return d.hs_monetary ?? null
    if (key === 'hs_trade') return d.hs_trade ?? null
    if (key === 'hs_investment') return d.hs_investment ?? null
    if (key === 'hs_financial') return d.hs_financial ?? null
    if (key === 'hf_score') return d.hf_score ?? null
    if (key === 'pf_score') return d.pf_score ?? null
    if (key === 'ef_hfi') return d.ef_hfi ?? null
    if (key === 'pf_expression') return d.pf_expression ?? null
    if (key === 'pf_assembly') return d.pf_assembly ?? null
    return d.pf_rol ?? null
  }

  // ─── Datahenting ────────────────────────────────────────────────────────────

  async function loadJson<T>(url: string): Promise<T> {
    const r = await fetch(url)
    if (!r.ok) throw new Error(`Feil ved henting av ${url}: ${r.status}`)
    return r.json() as Promise<T>
  }

  // ─── Animert scatter (D3) ───────────────────────────────────────────────────

  const ANIM_MS = 550
  const PLAY_INTERVAL_MS = 700

  function buildAnimatedScatter(
    container: HTMLElement,
    ts: ScatterTs,
    yearDisplay: HTMLElement,
    slider: HTMLInputElement,
    yKey: YKey,
    xKey: XKey,
    legendContainer: HTMLElement | null,
  ) {
    const { years: allYears, byYear } = ts
    const years = allYears.filter((yr) =>
      (byYear[String(yr)] ?? []).some(
        (d) => getX(d, xKey) != null && getY(d, yKey) != null,
      ),
    )

    // Alle regioner — konsistent fargerommet
    const allRegions = [
      ...new Set(
        Object.values(byYear)
          .flat()
          .map((d) => d.region),
      ),
    ].sort()

    const W = container.clientWidth || 520
    const isSmall = W < 480
    const isLandscape = window.innerWidth > window.innerHeight && window.innerHeight < 600
    const H = isLandscape
      ? Math.min(460, Math.max(window.innerHeight * 0.6, 200))
      : 460
    const margin = { top: 16, right: 16, bottom: 56, left: 82 }
    const iW = W - margin.left - margin.right
    const iH = H - margin.top - margin.bottom

    const xScale = d3.scaleLinear(X_CONFIGS[xKey].domain, [0, iW])
    const xcfg = X_CONFIGS[xKey]
    const cfg = Y_CONFIGS[yKey]
    const yTickCount = isSmall ? Math.max(Math.ceil(cfg.ticks / 2), 3) : cfg.ticks
    const axisFontSize = isSmall ? '14px' : '11px'
    const yScale =
      cfg.scaleType === 'log'
        ? d3
            .scaleLog<number>(cfg.domain as [number, number], [iH, 0])
            .clamp(true)
        : d3
            .scaleLinear<number>(cfg.domain as [number, number], [iH, 0])
            .clamp(true)
    const color = d3
      .scaleOrdinal<string>()
      .domain(allRegions)
      .range(d3.schemeTableau10)

    const svg = d3
      .select(container)
      .append('svg')
      .attr('viewBox', `0 0 ${W} ${H}`)
      .attr('width', '100%')
      .style('display', 'block')

    const g = svg
      .append('g')
      .attr('transform', `translate(${margin.left},${margin.top})`)

    // Rutenett
    g.append('g')
      .attr('class', 'grid-x')
      .attr('transform', `translate(0,${iH})`)
      .call(
        d3
          .axisBottom(xScale)
          .ticks(10)
          .tickSize(-iH)
          .tickFormat(() => ''),
      )
      .call((g) => g.select('.domain').remove())
      .call((g) =>
        g
          .selectAll('line')
          .attr('stroke', 'var(--rule-light)')
          .attr('stroke-dasharray', '2,3'),
      )

    g.append('g')
      .attr('class', 'grid-y')
      .call(
        d3
          .axisLeft(yScale)
          .ticks(5)
          .tickSize(-iW)
          .tickFormat(() => ''),
      )
      .call((g) => g.select('.domain').remove())
      .call((g) =>
        g
          .selectAll('line')
          .attr('stroke', 'var(--rule-light)')
          .attr('stroke-dasharray', '2,3'),
      )

    // Akser
    g.append('g')
      .attr('class', 'x-axis')
      .attr('transform', `translate(0,${iH})`)
      .call(d3.axisBottom(xScale).ticks(isSmall ? 5 : 10))
      .call((g) => g.select('.domain').attr('stroke', 'var(--rule)'))
      .call((g) =>
        g
          .selectAll('text')
          .attr('fill', 'var(--ink-faint)')
          .attr('font-family', 'var(--f-body)')
          .attr('font-size', axisFontSize),
      )
      .call((g) => g.selectAll('.tick line').attr('stroke', 'var(--rule)'))

    g.append('g')
      .attr('class', 'y-axis')
      .call(
        d3
          // eslint-disable-next-line @typescript-eslint/no-explicit-any
          .axisLeft(yScale as any)
          .ticks(yTickCount)
          .tickFormat((d: { valueOf(): number }) => cfg.tickFormat(d)),
      )
      .call((g) => g.select('.domain').attr('stroke', 'var(--rule)'))
      .call((g) =>
        g
          .selectAll('text')
          .attr('fill', 'var(--ink-faint)')
          .attr('font-family', 'var(--f-mono)')
          .attr('font-size', axisFontSize),
      )
      .call((g) => g.selectAll('.tick line').attr('stroke', 'var(--rule)'))

    // Akseetiketter
    g.append('text')
      .attr('x', iW / 2)
      .attr('y', iH + 46)
      .attr('text-anchor', 'middle')
      .attr('fill', 'var(--ink-soft)')
      .attr('font-family', 'var(--f-body)')
      .attr('font-size', '12px')
      .text(xcfg.axisLabel)

    g.append('text')
      .attr('transform', 'rotate(-90)')
      .attr('x', -iH / 2)
      .attr('y', -68)
      .attr('text-anchor', 'middle')
      .attr('fill', 'var(--ink-soft)')
      .attr('font-family', 'var(--f-body)')
      .attr('font-size', '12px')
      .text(cfg.axisLabel)

    // Årstall som bakgrunns-watermark
    const yearWatermark = g
      .append('text')
      .attr('x', iW * 0.95)
      .attr('y', iH * 0.22)
      .attr('text-anchor', 'end')
      .attr('fill', 'var(--ink)')
      .attr('font-family', 'var(--f-display)')
      .attr('font-size', '80px')
      .attr('font-weight', '600')
      .attr('opacity', 0.07)
      .text(String(years[0]))

    // Tooltip
    const tooltip = d3
      .select(container)
      .append('div')
      .attr('class', 'scatter-tooltip')
      .style('opacity', '0')
      .style('position', 'absolute')
      .style('pointer-events', 'none')
      .style('background', 'var(--ivory)')
      .style('border', '1px solid var(--rule)')
      .style('border-radius', 'var(--radius)')
      .style('padding', '6px 10px')
      .style('font-family', 'var(--f-body)')
      .style('font-size', '12px')
      .style('color', 'var(--ink)')
      .style('white-space', 'nowrap')
      .style('z-index', '10')
      .style('box-shadow', 'var(--shadow-card)')

    // Lag for prikker
    const dotsG = g.append('g').attr('class', 'dots')

    // Update-funksjon
    function update(year: number, animated: boolean) {
      const data = (byYear[String(year)] ?? []).filter(
        (d) => getY(d, yKey) != null && getX(d, xKey) != null,
      )

      const dots = dotsG
        .selectAll<SVGCircleElement, ScatterEntry>('.dot')
        .data(data, (d) => d.iso3)

      // Exit
      dots
        .exit<ScatterEntry>()
        .transition()
        .duration(animated ? ANIM_MS / 2 : 0)
        .attr('opacity', 0)
        .remove()

      // Enter
      const entered = dots
        .enter()
        .append('circle')
        .attr('class', 'dot')
        .attr('r', 5)
        .attr('fill', (d) => color(d.region))
        .attr('stroke', 'none')
        .attr('opacity', animated ? 0 : 0.82)
        .attr('cx', (d) => xScale(getX(d, xKey)!))
        .attr('cy', (d) => yScale(getY(d, yKey)!))
        .style('cursor', 'pointer')
        .on('mouseover', function (event: MouseEvent, d: ScatterEntry) {
          d3.select(this)
            .attr('stroke', 'var(--ink)')
            .attr('stroke-width', 1.5)
            .attr('r', 7)
          const rect = container.getBoundingClientRect()
          tooltip
            .style('opacity', '1')
            .html(
              `<strong>${d.name}</strong><br>` +
                xcfg.tooltipFn(d) +
                '<br>' +
                cfg.tooltipFn(d),
            )
            .style('left', `${event.clientX - rect.left + 14}px`)
            .style('top', `${event.clientY - rect.top - 36}px`)
        })
        .on('mousemove', function (event: MouseEvent) {
          const rect = container.getBoundingClientRect()
          tooltip
            .style('left', `${event.clientX - rect.left + 14}px`)
            .style('top', `${event.clientY - rect.top - 36}px`)
        })
        .on('mouseout', function () {
          d3.select(this).attr('stroke', 'none').attr('r', 5)
          tooltip.style('opacity', '0')
        })

      if (animated) {
        entered
          .transition()
          .duration(ANIM_MS / 2)
          .attr('opacity', 0.82)
      }

      // Enter + update merged transition
      const merged = entered.merge(dots)
      if (animated) {
        merged
          .transition()
          .duration(ANIM_MS)
          .ease(d3.easeCubicInOut)
          .attr('cx', (d) => xScale(getX(d, xKey)!))
          .attr('cy', (d) => yScale(getY(d, yKey)!))
          .attr('opacity', 0.82)
      } else {
        merged
          .attr('cx', (d) => xScale(getX(d, xKey)!))
          .attr('cy', (d) => yScale(getY(d, yKey)!))
      }

      yearWatermark.text(String(year))
      yearDisplay.textContent = String(year)
      slider.value = String(year)
    }

    // ─── Legende ──────────────────────────────────────────────────────────────
    if (legendContainer) {
      legendContainer.innerHTML = ''
      for (const region of allRegions) {
        const item = document.createElement('span')
        item.className = 'legend-item'
        item.innerHTML =
          `<svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">` +
          `<circle cx="5" cy="5" r="5" fill="${color(region)}"/>` +
          `</svg> ${region}`
        legendContainer.appendChild(item)
      }
    }

    // Initial render — start på siste tilgjengelige år
    update(years[years.length - 1], false)
    return { update, years }
  }

  // ─── Play / pause-logikk ────────────────────────────────────────────────────

  function setupPlayback(
    getUpdateFn: () => (year: number, animated: boolean) => void,
    getYears: () => number[],
    playBtn: HTMLButtonElement,
    playIcon: HTMLElement,
    playLabel: HTMLElement,
    slider: HTMLInputElement,
    yearDisplay: HTMLElement,
  ): { pause: () => void; seekTo: (year: number) => void } {
    let currentIdx = getYears().length - 1
    let interval: ReturnType<typeof setInterval> | null = null

    function setYear(idx: number, animated: boolean) {
      const years = getYears()
      currentIdx = Math.max(0, Math.min(idx, years.length - 1))
      getUpdateFn()(years[currentIdx], animated)
    }

    function pause() {
      if (interval !== null) {
        clearInterval(interval)
        interval = null
      }
      playIcon.textContent = '▶'
      playLabel.textContent = 'Spill av'
      playBtn.setAttribute('aria-pressed', 'false')
    }

    function seekTo(year: number) {
      const idx = getYears().indexOf(year)
      if (idx !== -1) {
        currentIdx = idx
        getUpdateFn()(getYears()[currentIdx], false)
        slider.value = String(getYears()[currentIdx])
        yearDisplay.textContent = String(getYears()[currentIdx])
      }
    }

    function play() {
      if (interval !== null) return
      // Hopp til start hvis vi er på slutten
      const years = getYears()
      if (currentIdx >= years.length - 1) setYear(0, false)
      playIcon.textContent = '⏸'
      playLabel.textContent = 'Pause'
      playBtn.setAttribute('aria-pressed', 'true')
      interval = setInterval(() => {
        const next = currentIdx + 1
        if (next >= getYears().length) {
          pause()
          return
        }
        setYear(next, true)
      }, PLAY_INTERVAL_MS)
    }

    playBtn.addEventListener('click', () => {
      if (interval !== null) pause()
      else play()
    })

    const years = getYears()
    slider.min = String(years[0])
    slider.max = String(years[years.length - 1])
    slider.value = String(years[years.length - 1])
    slider.addEventListener('input', () => {
      pause()
      const year = parseInt(slider.value, 10)
      const idx = getYears().indexOf(year)
      if (idx !== -1) setYear(idx, true)
    })

    // Tastatur: space = play/pause, pil venstre/høyre = år
    document.addEventListener('keydown', (e) => {
      if (e.target !== document.body && e.target !== playBtn) return
      if (e.code === 'Space') {
        e.preventDefault()
        if (interval !== null) pause()
        else play()
      }
      if (e.code === 'ArrowRight') {
        e.preventDefault()
        pause()
        setYear(currentIdx + 1, true)
      }
      if (e.code === 'ArrowLeft') {
        e.preventDefault()
        pause()
        setYear(currentIdx - 1, true)
      }
    })

    return { pause, seekTo }
  }

  // ─── Init ────────────────────────────────────────────────────────────────────

  async function init() {
    const ts = await loadJson<ScatterTs>('/data/freedom-scatter-ts.json')

    const sections = document.querySelectorAll<HTMLElement>('section.section')

    for (const section of sections) {
      const scatterContainer =
        section.querySelector<HTMLElement>('.scatter-chart')
      const yearDisplay = section.querySelector<HTMLElement>('.year-display')
      const slider = section.querySelector<HTMLInputElement>('.year-slider')
      const playBtn = section.querySelector<HTMLButtonElement>('.play-btn')
      const playIcon = section.querySelector<HTMLElement>('.play-icon')
      const playLabel = section.querySelector<HTMLElement>('.play-label')
      const legendContainer =
        section.querySelector<HTMLElement>('.scatter-legend')

      if (
        !scatterContainer ||
        !yearDisplay ||
        !slider ||
        !playBtn ||
        !playIcon ||
        !playLabel
      ) {
        continue
      }

      const container = scatterContainer
      let scatterUpdate: (year: number, animated: boolean) => void = () => {}
      let scatterYears: number[] = []
      let currentYKey = (container.dataset.defaultY || 'gdp_real') as YKey
      let currentXKey = (container.dataset.defaultX || 'hs') as XKey

      function buildScatterWithKey(yKey: YKey, xKey: XKey) {
        container.innerHTML = ''
        const result = buildAnimatedScatter(
          container,
          ts,
          yearDisplay!,
          slider!,
          yKey,
          xKey,
          legendContainer,
        )
        scatterUpdate = result.update
        scatterYears = result.years
      }

      // Find the best year to display for a given X/Y combo.
      // Keeps currentYear if it has data; otherwise returns the latest year that does.
      function bestYearFor(
        xKey: XKey,
        yKey: YKey,
        preferredYear: number,
      ): number {
        const hasData = (yr: number) =>
          (ts.byYear[String(yr)] ?? []).some(
            (d) => getX(d, xKey) != null && getY(d, yKey) != null,
          )
        if (hasData(preferredYear)) return preferredYear
        for (let i = ts.years.length - 1; i >= 0; i--) {
          if (hasData(ts.years[i])) return ts.years[i]
        }
        return preferredYear
      }

      buildScatterWithKey(currentYKey, currentXKey)

      const playbackCtrl = setupPlayback(
        () => scatterUpdate,
        () => scatterYears,
        playBtn,
        playIcon,
        playLabel,
        slider,
        yearDisplay,
      )

      const yBtns = section.querySelectorAll<HTMLButtonElement>('.y-btn')
      yBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const newKey = btn.dataset.ykey as YKey
          if (newKey === currentYKey) return
          currentYKey = newKey
          yBtns.forEach((b) =>
            b.classList.toggle('active', b.dataset.ykey === newKey),
          )
          playbackCtrl.pause()
          const currentYear = parseInt(slider.value, 10)
          buildScatterWithKey(currentYKey, currentXKey)
          playbackCtrl.seekTo(
            bestYearFor(currentXKey, currentYKey, currentYear),
          )
        })
      })

      let resizeTimer: ReturnType<typeof setTimeout>
      const ro = new ResizeObserver(() => {
        clearTimeout(resizeTimer)
        resizeTimer = setTimeout(() => {
          const currentYear = parseInt(slider.value, 10)
          playbackCtrl.pause()
          buildScatterWithKey(currentYKey, currentXKey)
          playbackCtrl.seekTo(currentYear)
        }, 150)
      })
      ro.observe(section)

      const xSelect = section.querySelector<HTMLSelectElement>('.x-select')
      if (xSelect) {
        xSelect.addEventListener('change', () => {
          const newXKey = xSelect.value as XKey
          if (newXKey === currentXKey) return
          currentXKey = newXKey
          playbackCtrl.pause()
          const currentYear = parseInt(slider.value, 10)
          buildScatterWithKey(currentYKey, currentXKey)
          playbackCtrl.seekTo(
            bestYearFor(currentXKey, currentYKey, currentYear),
          )
        })
      }
    }
  }

  init().catch(console.error)
</script>

