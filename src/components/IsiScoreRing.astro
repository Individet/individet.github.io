---
interface Props {
  score: number
  label?: string
  showValue?: boolean
  size?: number
}

const {
  score,
  label = `ISI-score ${score}`,
  showValue = true,
  size = 68,
} = Astro.props
const clampedScore = Math.max(0, Math.min(100, score))
const strokeWidth = 7
const radius = size / 2 - strokeWidth / 2
const circumference = 2 * Math.PI * radius
const dashOffset = circumference * (1 - clampedScore / 100)
const progressHue = Math.round(clampedScore * 1.2)
const progressColor = `hsl(${progressHue} 72% 42%)`
const trackColor = `hsl(${progressHue} 75% 86%)`
---

<div
  class="score-ring"
  style={`--score-ring-track: ${trackColor}; --score-ring-progress: ${progressColor}; --score-ring-size: ${size}px;`}
  aria-label={label}
  title={label}
>
  <svg
    class="score-ring__svg"
    viewBox={`0 0 ${size} ${size}`}
    width={size}
    height={size}
    aria-hidden="true"
  >
    <circle class="score-ring__track" cx={size / 2} cy={size / 2} r={radius} />
    <circle
      class="score-ring__progress"
      cx={size / 2}
      cy={size / 2}
      r={radius}
      stroke-dasharray={circumference}
      stroke-dashoffset={dashOffset}
    />
  </svg>
  {showValue && <span class="score-ring__value">{clampedScore}</span>}
</div>

<style>
  .score-ring {
    position: relative;
    display: grid;
    place-items: center;
    inline-size: var(--score-ring-size);
    block-size: var(--score-ring-size);
    flex: 0 0 auto;
  }

  .score-ring__svg {
    position: absolute;
    inset: 0;
    transform: rotate(-90deg);
    overflow: visible;
  }

  .score-ring__track,
  .score-ring__progress {
    fill: none;
    stroke-width: 8;
  }

  .score-ring__track {
    stroke: var(--score-ring-track);
  }

  .score-ring__progress {
    stroke: var(--score-ring-progress);
    stroke-linecap: butt;
    transition:
      stroke-dashoffset 180ms ease,
      stroke 180ms ease;
  }

  .score-ring::before {
    content: '';
    position: absolute;
    inset: calc(10px + (68px - var(--score-ring-size)) * 0.03);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(17, 32, 45, 0.12);
    z-index: 0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .score-ring__value {
    position: relative;
    z-index: 1;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--ink);
  }
</style>
