---
import type { CollectionEntry } from 'astro:content'
import ActorPortrait from './ActorPortrait.astro'
import { getActorPortrait } from '../lib/actorPortraits'
import { getIsiClass, getIsiScore } from '../lib/isi'
import IsiScoreRing from './IsiScoreRing.astro'

interface Props {
  report: CollectionEntry<'isi'>
}

const { report } = Astro.props
const isiClass = getIsiClass(report)
const portrait = getActorPortrait(report.data.actorSlug, report.data.actorName)

function formatDate(value: Date): string {
  const day = String(value.getUTCDate()).padStart(2, '0')
  const month = String(value.getUTCMonth() + 1).padStart(2, '0')
  const year = value.getUTCFullYear()

  return `${day}.${month}.${year}`
}
---

<a class="report-list__link" href={`/isi/${report.id.replace(/\.md$/, '')}/`}>
  <span class="report-list__portrait">
    <ActorPortrait portrait={portrait} />
  </span>
  <span class="report-list__content">
    <span class="report-list__topline">
      <span class="report-list__name">
        {report.data.actorName} ({report.data.actorType})
      </span>
      <span class="report-list__class">{isiClass}</span>
    </span>
    <span class="report-list__affiliation">
      {report.data.actorAffiliation}
    </span>

    {
      report.data.tags.length > 0 && (
        <span class="report-list__bottom">
          <span class="report-list__tags" aria-label="Tagger">
            {report.data.tags.map((tag) => (
              <span class="report-list__tag">{tag}</span>
            ))}
          </span>
        </span>
      )
    }

    <span class="report-list__updated">
      Sist oppdatert: {formatDate(report.data.lastUpdated)}
    </span>
  </span>
  <span class="report-list__score">
    <IsiScoreRing
      score={getIsiScore(report)}
      label={`${report.data.actorName}: ${getIsiScore(report)}`}
    />
  </span>
</a>

<style>
  .report-list__link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.05rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: 1.45rem;
    text-decoration: none;
    color: inherit;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(247, 241, 227, 0.8) 100%);
    box-shadow: 0 16px 36px rgba(8, 19, 29, 0.08);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .report-list__link:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 24px 48px rgba(8, 19, 29, 0.12);
    border-color: var(--line-strong);
  }

  .report-list__name {
    font-size: 1.05rem;
    font-weight: 700;
    text-wrap: balance;
    line-height: 1.3;
  }

  .report-list__portrait {
    display: inline-flex;
    flex: 0 0 auto;
  }

  .report-list__score {
    display: inline-flex;
    flex: 0 0 auto;
    align-self: center;
  }

  .report-list__content {
    min-width: 0;
    display: grid;
    gap: 0.45rem;
    width: 100%;
  }

  .report-list__topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 0.7rem;
    align-items: baseline;
    justify-content: space-between;
  }

  .report-list__class {
    font-size: 0.96rem;
    font-weight: 600;
    color: var(--teal);
  }

  .report-list__affiliation {
    font-size: 0.95rem;
    line-height: 1.35;
    color: var(--muted);
  }

  .report-list__bottom {
    margin-top: 0.2rem;
  }

  .report-list__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .report-list__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.72);
    font-size: 0.82rem;
    line-height: 1;
  }

  .report-list__updated {
    margin-top: 0.2rem;
    font-size: 0.83rem;
    color: var(--muted);
    font-style: italic;
  }

  @media (max-width: 560px) {
    .report-list__link {
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-areas:
        'portrait . score'
        'content content content';
      align-items: start;
      column-gap: 0.85rem;
      row-gap: 0.8rem;
      padding: 0.95rem;
      border-radius: 1.2rem;
    }

    .report-list__portrait {
      grid-area: portrait;
    }

    .report-list__content {
      grid-area: content;
    }

    .report-list__name {
      font-size: 1rem;
    }

    .report-list__class {
      font-size: 0.92rem;
    }

    .report-list__affiliation {
      font-size: 0.92rem;
    }

    .report-list__score {
      grid-area: score;
      justify-self: end;
      align-self: flex-start;
    }
  }
</style>
