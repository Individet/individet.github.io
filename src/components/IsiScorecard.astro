---
import { getIsiClassFromScore } from '../lib/isi'

const { data, rawScore, isiScore } = Astro.props
const isiClass = getIsiClassFromScore(isiScore)

const dimensionLabels = {
  d1: 'D1 Kroppslig autonomi og selvbestemmelse',
  d2: 'D2 Ytringsfrihet og intellektuell autonomi',
  d3: 'D3 Eiendomsrett og økonomisk frihet',
  d4: 'D4 Rettsstat og beskyttelse mot vilkårlighet',
  d5: 'D5 Frivillig fellesskap og sivilsamfunn',
  d6: 'D6 Digital autonomi og personvern',
}

const underdimensionLabels = {
  d1_1: '1.1 Medisinsk selvbestemmelse',
  d1_2: '1.2 Livsstilsautonomi',
  d1_3: '1.3 Bevegelsesfrihet',
  d1_4: '1.4 Selvbestemmelse ved livets slutt',
  d2_1: '2.1 Ytringsfrihet - innhold',
  d2_2: '2.2 Pressefrihet og redaksjonell uavhengighet',
  d2_3: '2.3 Akademisk og vitenskapelig frihet',
  d2_4: '2.4 Ytringsfrihet på digitale plattformer',
  d3_1: '3.1 Eiendomsvern',
  d3_2: '3.2 Skatt og tvungen omfordeling',
  d3_3: '3.3 Naeringsfrihet og regulering',
  d3_4: '3.4 Arbeidsmarkedsfrihet',
  d3_5: '3.5 Handelsfrihet',
  d3_6: '3.6 Monetaer frihet',
  d4_1: '4.1 Lik anvendelse av loven',
  d4_2: '4.2 Rettslig uavhengighet',
  d4_3: '4.3 Rettssikkerhet og uskyldspresumpsjon',
  d4_4: '4.4 Begrenset statsmakt',
  d5_1: '5.1 Religionsfrihet',
  d5_2: '5.2 Politisk foreningsfrihet',
  d5_3: '5.3 Sivilsamfunn vs. statlig substitusjon',
  d5_4: '5.4 Forsamlingsfrihet',
  d6_1: '6.1 Overvaakning og personvern',
  d6_2: '6.2 Digital identitet og kontroll',
  d6_3: '6.3 Internettfrihet og kryptering',
  d6_4: '6.4 Eierskap til egne data',
}

function formatScore(value) {
  return value > 0 ? `+${value}` : `${value}`
}
---

<section class="isi-scorecard" aria-label="Skårtabell fra frontmatter">
  <div class="isi-scorecard__summary">
    <dl class="isi-scorecard__metrics">
      <div class="isi-scorecard__metric">
        <dt>ISI-skår</dt>
        <dd>{isiScore} <span>(råskår {formatScore(rawScore)})</span></dd>
      </div>
      <div class="isi-scorecard__metric">
        <dt>Klassifisering</dt>
        <dd>{isiClass}</dd>
      </div>
    </dl>
  </div>

  <section class="isi-scorecard__panel">
    <h4>Dimensjoner og delskårer</h4>
    <table>
      <thead>
        <tr>
          <th scope="col">Dimensjon</th>
          <th scope="col">Skår</th>
        </tr>
      </thead>
      <tbody>
        {Object.entries(data.scores).map(([dimensionKey, dimensionValues]) => (
          <>
            <tr class="isi-scorecard__dimension-row">
              <th scope="row">{dimensionLabels[dimensionKey] ?? dimensionKey}</th>
              <td class="isi-scorecard__score">{formatScore(dimensionValues.total)}</td>
            </tr>
            {Object.entries(dimensionValues)
              .filter(([subKey]) => subKey !== 'total')
              .map(([subKey, score]) => (
                <tr>
                  <td class="isi-scorecard__subdimension">
                    {underdimensionLabels[subKey] ?? subKey}
                  </td>
                  <td class="isi-scorecard__score">{formatScore(score)}</td>
                </tr>
              ))}
          </>
        ))}
      </tbody>
    </table>
  </section>

  <section class="isi-scorecard__panel">
    <h4>Datamangler</h4>
    <p>{data.dataGaps}</p>
  </section>
</section>
