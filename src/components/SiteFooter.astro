---
import { SITE } from "../lib/seo";
---

<footer class="site-footer">
  <p>
    Individet er startet og drives av <strong>Lars-Erik Bruce</strong>. Innhold
    publiseres fortløpende på <strong>www.individet.no</strong>.
    <a href="/rss.xml" class="site-footer__link">RSS-feed</a>. Følg tankesmien
    på <a
      href={SITE.facebookUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="site-footer__link">Facebook</a
    >.
  </p>
</footer>

<style>
  .site-footer {
    color: #555;
    font-size: 0.9rem;
    margin-top: 2.5rem;
    margin-bottom: 3rem;
  }

  .site-footer__link {
    font-size: 0.9rem;
    font-weight: bold;
    text-decoration: none;
    color: #274c77;
  }

  .site-footer__link:hover {
    text-decoration: underline;
  }
</style>
