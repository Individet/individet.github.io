---
import { SITE } from '../lib/seo'
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand__name">Individet</div>
        <div class="footer-brand__sub">
          Frihet · Presisjon · Etterrettelighet
        </div>
        <p class="footer-brand__desc">
          Individet er startet og drives av <strong>Lars-Erik Bruce</strong>.
          Nettstedet publiserer analyser, manifest og åpne arbeidsprosesser.
        </p>
      </div>

      <div>
        <div class="footer-col__label">Navigasjon</div>
        <div class="footer-col__links">
          <a href="/">Forside</a>
          <a href="/manifest/">Manifest</a>
          <a href="/isi/">ISI-analyser</a>
          <a href="/om/">Om Individet</a>
        </div>
      </div>

      <div>
        <div class="footer-col__label">Ressurser</div>
        <div class="footer-col__links">
          <a href={SITE.githubUrl} target="_blank" rel="noopener noreferrer"
            >GitHub</a
          >
          <a href="/rss.xml">RSS-feed</a>
          <a href={SITE.facebookUrl} target="_blank" rel="noopener noreferrer"
            >Facebook</a
          >
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© 2025–2026 Individet · {SITE.url.replace('https://', '')}</span>
      <div class="footer-social">
        <a href="/rss.xml">RSS</a>
        <a href={SITE.githubUrl} target="_blank" rel="noopener noreferrer"
          >GitHub</a
        >
        <a href={SITE.facebookUrl} target="_blank" rel="noopener noreferrer"
          >Facebook</a
        >
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: rgba(255, 255, 255, 0.55);
    padding: 3.5rem 0 2rem;
    position: relative;
    z-index: 1;
  }

  .site-footer__inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 2rem;
  }

  .footer-brand__name {
    font-family: var(--f-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--ivory);
    margin-bottom: 0.3rem;
  }

  .footer-brand__sub {
    font-family: var(--f-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--terracotta-l);
    margin-bottom: 1rem;
  }

  .footer-brand__desc {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    max-width: 300px;
    margin: 0;
  }

  .footer-brand__desc strong {
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-col__label {
    font-family: var(--f-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 1rem;
  }

  .footer-col__links {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer-col__links a {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-col__links a:hover {
    color: var(--terracotta-l);
    text-decoration: none;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.55);
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-social {
    display: flex;
    gap: 1.2rem;
  }

  .footer-social a {
    font-family: var(--f-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-social a:hover {
    color: var(--gold);
    text-decoration: none;
  }

  @media (max-width: 860px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-grid > :first-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .site-footer {
      padding: 2.5rem 0 1.5rem;
    }

    .site-footer__inner {
      padding: 0 1.25rem;
    }

    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
