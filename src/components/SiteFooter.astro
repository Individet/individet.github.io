---
import Icon from './Icon.astro'
import { SITE } from '../lib/seo'
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <a href="/" class="site-footer__banner" aria-label="Gå til forsiden">
        <span class="site-footer__eyebrow">Tankesmien Individet</span>
        <span class="site-footer__wordmark">Tilbake til forsiden</span>
        <span class="site-footer__tagline">
          Et hjem for analyser av frihet, suverenitet og ansvar.
        </span>
      </a>
    </div>

    <div class="site-footer__bottom">
      <div class="site-footer__meta">
        <p>
          Individet er startet og drives av <strong>Lars-Erik Bruce</strong>.
          Nettstedet publiserer analyser, manifest og åpne arbeidsprosesser for
          <strong>www.individet.no</strong>.
        </p>
      </div>

      <div class="site-footer__links" aria-label="Eksterne lenker">
        <a href="/rss.xml" class="site-footer__link">
          <Icon name="rss" />
          <span>RSS</span>
        </a>
        <a
          href={SITE.facebookUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__link"
        >
          <Icon name="facebook" />
          <span>Facebook</span>
        </a>
        <a
          href={SITE.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__link"
        >
          <Icon name="github" />
          <span>GitHub</span>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 0 1rem 2.5rem;
  }

  .site-footer__inner {
    width: min(100%, var(--shell-width));
    margin: 0 auto;
    padding: 1.15rem;
    display: grid;
    gap: 1.25rem;
    border-radius: 1.75rem;
    border: 1px solid var(--line-strong);
    background:
      linear-gradient(180deg, rgba(255, 251, 243, 0.94), rgba(244, 238, 226, 0.9)),
      var(--surface-2);
    box-shadow:
      0 28px 70px rgba(8, 19, 29, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
  }

  .site-footer__top {
    display: flex;
    justify-content: center;
  }

  .site-footer__banner {
    display: grid;
    gap: 0.18rem;
    width: min(100%, 36rem);
    padding: 1rem 1.15rem;
    border-radius: 1.2rem;
    border: 1px solid rgba(16, 40, 56, 0.12);
    background:
      radial-gradient(circle at top right, rgba(185, 148, 83, 0.16), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(245, 238, 225, 0.78));
    color: var(--ink);
    text-decoration: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .site-footer__banner:hover {
    color: var(--ink);
    text-decoration: none;
  }

  .site-footer__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent-strong);
  }

  .site-footer__wordmark {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .site-footer__tagline {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--muted);
  }

  .site-footer__bottom {
    display: grid;
    gap: 1rem;
    align-items: center;
  }

  .site-footer__meta {
    display: grid;
    gap: 0.8rem;
    padding: 0;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .site-footer__meta p {
    margin: 0;
  }

  .site-footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    justify-content: flex-start;
  }

  .site-footer__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 5rem;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.6);
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .site-footer__link:hover {
    transform: translateY(-1px);
    border-color: rgba(16, 40, 56, 0.2);
    background: rgba(255, 255, 255, 0.88);
    text-decoration: none;
  }

  @media (min-width: 760px) {
    .site-footer__bottom {
      grid-template-columns: minmax(0, 1.4fr) auto;
    }
  }

  @media (max-width: 560px) {
    .site-footer {
      padding: 0 0.75rem 2rem;
    }

    .site-footer__inner {
      padding: 0.9rem;
      border-radius: 1.4rem;
    }

    .site-footer__banner {
      width: 100%;
    }
  }
</style>
